!DWDMAgent/reports/.gitkeep
!DWDMAgent/sample_output/.gitkeep

# Docs are private for now
*.md

# Experimental comparison scripts (do not upload)
DWDMAgent/qwen_compare.py
DWDMAgent/*compare*.py
DWDMAgent/*qwen*.py

# Local deployment units (contain environment-specific user/group)
DWDMAgent/systemd/

# OS noise
.DS_Store
