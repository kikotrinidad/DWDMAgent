# Secrets and local environment
.env
.env.*
!.env.example

# User/editor local config
.vscode/

# Python cache/bytecode
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Runtime logs
*.log
DWDMAgent/logs/

# Generated reports and sample outputs
DWDMAgent/reports/**
DWDMAgent/sample_output/**

